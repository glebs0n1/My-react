{
  "name": "my-react-app",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@emotion/react": "^11.13.3",
    "@emotion/styled": "^11.13.0",
    "@mui/material": "^6.1.2",
    "@testing-library/jest-dom": "^5.17.0",
    "@testing-library/react": "^13.4.0",
    "@testing-library/user-event": "^13.5.0",
    "axios": "^1.13.2",
    "framer-motion": "^12.33.0",
    "lucide-react": "^0.562.0",
    "playwright": "^1.57.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-helmet-async": "^2.0.5",
    "react-hot-toast": "^2.6.0",
    "react-icons": "^5.5.0",
    "react-redux": "^9.1.2",
    "react-router-dom": "^6.28.0",
    "react-scripts": "^5.0.1",
    "react-slick": "^0.31.0",
    "redux": "^5.0.1",
    "redux-thunk": "^3.1.0",
    "scroll-lock": "^2.1.5",
    "slick-carousel": "^1.8.1",
    "web-vitals": "^2.1.4",
    "yet-another-react-lightbox": "^3.28.0",
    "yup": "^1.4.0"
  },
  "scripts": {
    "start": "NODE_OPTIONS=--max-old-space-size=8192 PORT=4000 react-scripts start",
    "build": "react-scripts build",
    "postbuild": "react-snap",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "reactSnap": {
    "source": "build",
    "destination": "build",
    "include": [
      "/",
      "/apie-mus",
      "/dazniausiai-uzduodami-klausimai",
      "/prieglaudos",
      "/veterinaras",
      "/dresura",
      "/kirpimas",
      "/darbas",
      "/kontaktai",
      "/dogs",
      "/cats",
      "/other-animals",
      "/medications",
      "/health/skubus-atvejai",
      "/medications/allergies-itching",
      "/medications/anxiety-sedation"
    ],
    "skipThirdPartyRequests": true,
    "puppeteerArgs": ["--no-sandbox", "--disable-setuid-sandbox"],
    "minifyHtml": { "collapseWhitespace": false, "removeComments": false },
    "inlineCss": false
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest",
      "plugin:storybook/recommended"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@chromatic-com/storybook": "^1.8.0",
    "@storybook/addon-essentials": "^8.2.9",
    "@storybook/addon-interactions": "^8.2.9",
    "@storybook/addon-links": "^8.2.9",
    "@storybook/addon-onboarding": "^8.2.9",
    "@storybook/blocks": "^8.2.9",
    "@storybook/react-webpack5": "^8.2.9",
    "@storybook/test": "^8.2.9",
    "@types/react": "^18.3.27",
    "@types/react-dom": "^18.3.7",
    "@types/react-slick": "^0.23.13",
    "depcheck": "^1.4.7",
    "eslint-config-react-app": "^7.0.1",
    "eslint-plugin-storybook": "^0.8.0",
    "postcss": "^8.4.31",
    "postcss-preset-env": "^7.8.3",
    "postcss-selector-parser": "^6.0.13",
    "prop-types": "^15.8.1",
    "react-snap": "^1.23.0",
    "storybook": "^8.2.9",
    "typescript": "^4.9.5",
    "webpack": "^5.94.0"
  }
}
